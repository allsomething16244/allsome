{
  "expo": {
    "name": "allsome",
    "slug": "allsome",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "allsome",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.allsome.app"
    },
    "android": {
      "package": "com.allsome.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "생체 인증을 사용해 로그인합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B6B"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "abbf1127-9f2d-49f9-9f89-32f483b36572"
      }
    },
    "owner": "allsomething"
  }
}
